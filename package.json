{
  "name": "scriptz",
  "version": "0.1.0",
  "description": "CLI utilities for recording terminal sessions",
  "type": "module",
  "bin": {
    "scriptz": "dist/cli/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "release": "npm version minor && git push --follow-tags",
    "install-latest": "npm install -g https://github.com/hekonsek/spex/archive/refs/tags/v${npm_package_version}.tar.gz"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
